# --- Database (Neon Postgres) ---
# From the Neon integration on Vercel Marketplace, or your Neon dashboard.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Better Auth ---
# Generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=
# Base URL of the app (no trailing slash). Production: https://www.splitza.app
BETTER_AUTH_URL=http://localhost:3000

# --- Google OAuth (Sign in with Google) ---
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID (Web).
# Authorized redirect URI: <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Email (Resend) ---
# Optional. Without it, password reset, friend requests, and bill shares still
# work in-app — only the email notifications are skipped. Get a key at
# https://resend.com/api-keys. Note: the default onboarding@resend.dev sender
# only delivers to your own account email; verify a domain to email anyone else.
RESEND_API_KEY=
# Optional sender override once you've verified a domain.
# EMAIL_FROM=Splitza <hello@splitza.app>

# --- In-app feedback ---
# Where feedback submitted from the dashboard form is delivered (sent via Resend).
# FEEDBACK_EMAIL=you@example.com

# --- AI receipt scanning (OpenRouter) ---
# Get a free API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional: force a specific model instead of the built-in free-model fallback chain
# OPENROUTER_MODEL=google/gemma-4-31b-it:free
